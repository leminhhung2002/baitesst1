# Cấu hình chạy LOCAL trên máy không có Postgres -> dùng SQLite (1 file koc.db).
# Muốn dùng Postgres: đổi dòng DATABASE_URL bên dưới.
DATABASE_URL=sqlite:///./koc.db

# Nguồn dữ liệu THẬT: ~90 KOC VN từ bảng xếp hạng follower + avatar thật.
DATA_SOURCE=tiktok_top
SEED_FALLBACK_SOURCE=
TIKTOK_HANDLES=
# Ngưỡng lọc follower: loại KOC dưới mức này khi đồng bộ.
MIN_FOLLOWER=500000

# (Tuỳ chọn) Key unavatar.io miễn phí -> tải avatar TikTok ổn định. Để trống
# thì tải ẩn danh (bị giới hạn tần suất, nhiều KOC sẽ hiện avatar chữ cái).
UNAVATAR_KEY=

AUTO_SYNC_ENABLED=true
SYNC_INTERVAL_MINUTES=60
SEED_ON_STARTUP=true
CORS_ORIGINS=http://localhost:5173
