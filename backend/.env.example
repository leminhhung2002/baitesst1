DATABASE_URL=postgresql+psycopg2://koc:koc@localhost:5432/koc

# Nguồn dữ liệu:
#   tiktok_oembed -> mặc định. Danh tính (tên/link/avatar) THẬT từ TikTok oEmbed
#                    công khai; follower THẬT từ bảng tuyển chọn CURATED_KOCS.
#   real          -> provider bên thứ ba (cần API key, xem app/sources/real.py)
DATA_SOURCE=tiktok_oembed

# Nếu seed lần đầu bằng nguồn thật lỗi -> tự seed bằng nguồn này. RỖNG = tắt (không dùng mock).
SEED_FALLBACK_SOURCE=

# Chỉ dùng khi DATA_SOURCE=tiktok_oembed. Danh sách handle (không @), cách nhau dấu phẩy.
# Để trống -> dùng danh sách KOC TUYỂN CHỌN trong adapter (handle phải có trong CURATED_KOCS).
TIKTOK_HANDLES=

# Ngưỡng lọc follower: loại KOC dưới mức này khi đồng bộ.
MIN_FOLLOWER=500000

# (Tuỳ chọn) Key unavatar.io miễn phí để tải avatar TikTok ổn định (50 req/ngày).
# Đăng ký tại https://unavatar.io. Để trống -> tải ẩn danh (dễ bị 429 -> avatar chữ cái).
UNAVATAR_KEY=

AUTO_SYNC_ENABLED=true
SYNC_INTERVAL_MINUTES=60
SEED_ON_STARTUP=true
CORS_ORIGINS=http://localhost:5173

# --- chỉ cần khi DATA_SOURCE=real ---
REAL_API_BASE_URL=
REAL_API_KEY=
